# ── Frontend (Vite) — build-time ─────────────────────────────────────
# Copy to `.env` / `.env.local` as needed.

# Base URL of the content API. Leave EMPTY in production: the Go server serves
# the SPA and the API from the same origin (relative /api/content). Set this
# only for local dev when the Vite dev server (5173) talks to the Go server:
#   VITE_API_BASE=http://localhost:8080
VITE_API_BASE=

# Built-in default prep window + hazards (used until content is published).
VITE_PREP_DAYS=3
VITE_HAZARDS=winter,flood,hurricane,shelter

# ── Server (Go binary) — runtime env on the VPS ──────────────────────
# (set these in the systemd unit / shell, NOT in the Vite .env)
#
#   PORT=8080                 # port the binary listens on (behind your proxy)
#   CONTENT_DIR=/var/lib/disasterprep   # where content.json, config.json + backups live
#
# SELF-SUFFICIENT CONFIG: EVENT_NAME, EMAIL_WEBHOOK_URL, and ADMIN_PASSPHRASE
# below are FIRST-RUN SEEDS only. On first boot they're written to
# <CONTENT_DIR>/config.json (the passphrase hashed); after that you manage them
# from the admin → Config tab — no env edits or restart. config.json wins once
# it exists; delete it to re-seed from these.
#
#   EVENT_NAME="Spring Expo 2026"  # analytics label; shown/segmented in the admin Report tab (defaults to "booth")
#
# Auth MODE is auto-selected from the env and STAYS env-driven:
#   • If ENTRA_TENANT_ID + ENTRA_CLIENT_ID are set → Entra/M365 SSO.
#   • else if a passphrase is set (env seed or config) → shared passphrase.
#   • else                                       → writes disabled (read-only).
#
#   ADMIN_PASSPHRASE=<long random string>   # initial gate secret; rotate later in admin → Config (stored hashed)
#   ENTRA_TENANT_ID=<your M365 tenant (directory) id>
#   ENTRA_CLIENT_ID=<the SPA app registration's client id>
#   ENTRA_ALLOWED_GROUP=<optional: object id of a security group that may edit>
#
# Email (Power Automate): seed the webhook here; manage it later in admin → Config.
# Leave empty to disable email; the PDF download still works.
#   EMAIL_WEBHOOK_URL=https://prod-xx.eastus.logic.azure.com:443/workflows/...
